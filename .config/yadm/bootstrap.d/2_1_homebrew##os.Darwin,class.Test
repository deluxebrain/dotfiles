#!/bin/bash

# Homebrew and homebrew packages
# for Darwin OS when running on test account

set -e

echo "Running bootstrap file: $(basename "$0")" >&2

# Best practices on multiuser system are to install Homebrew into
# the account of the primary ( not test ) user
# Hence check its present and exit with error if not
if ! command -v brew >/dev/null 2>&1; then
    echo ERROR: Homebrew not installed >&2
    exit 1
fi
echo Nothing todo for non-primary user on multiuser system >&2
